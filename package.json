{
  "name": "hjson-topology-toolkit",
  "version": "1.0.0",
  "type": "module",
  "description": "强大的HJSON/JSON拓扑结构处理工具包，支持遍历、查找、转换、验证等功能",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./async": {
      "import": {
        "types": "./dist/async.d.ts",
        "default": "./dist/async.mjs"
      },
      "require": {
        "types": "./dist/async.d.ts",
        "default": "./dist/async.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c && tsc --emitDeclarationOnly",
    "dev": "rollup -c -w",
    "typecheck": "tsc --noEmit",
    "benchmark": "node benchmark/index.js",
    "prepublishOnly": "npm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "hjson",
    "json",
    "topology",
    "tree",
    "traverse",
    "transform",
    "validate",
    "schema",
    "chain",
    "functional"
  ],
  "author": "Your Name",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "hjson": "^3.2.2"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/node": "^20.10.0",
    "lodash": "^4.17.21",
    "rollup": "^4.6.1",
    "tslib": "^2.6.2",
    "typescript": "^5.3.2",
    "vitepress": "^1.6.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/hjson-topology-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/hjson-topology-toolkit/issues"
  },
  "homepage": "https://github.com/yourusername/hjson-topology-toolkit#readme"
}
